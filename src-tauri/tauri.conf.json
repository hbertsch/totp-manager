{
  "productName": "TOTP Manager",
  "version": "2.0.4",
  "identifier": "com.hbertsch.totp-manager",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "TOTP Manager",
        "width": 900,
        "height": 1500,
        "minWidth": 600,
        "maxWidth": 1200,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
